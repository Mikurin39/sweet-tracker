# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — server-side only (used by the receipt OCR route).
# Free API key from https://aistudio.google.com (no credit card required).
GEMINI_API_KEY=
